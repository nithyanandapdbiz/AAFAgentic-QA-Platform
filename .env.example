OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JIRA_URL=https://your-site.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token-here
PROJECT_KEY=SCRUM

# Zephyr Essential Cloud API v2.8
# Base URL (default is https://prod-api.zephyr4jiracloud.com/v2)
ZEPHYR_BASE_URL=https://prod-api.zephyr4jiracloud.com/v2
# API Token from: Jira → Apps → Zephyr Essentials → API Keys
ZEPHYR_ACCESS_KEY=your-zephyr-access-key-here

ISSUE_KEY=SCRUM-6
# Issue type used when auto-creating failure tickets (must exist in your project)
JIRA_BUG_ISSUETYPE=Task
PORT=3000
