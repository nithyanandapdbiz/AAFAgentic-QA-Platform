# ── OpenAI (optional — only needed if using LLM-based generation) ──────────
OPENAI_API_KEY=your-openai-api-key-here

# ── Jira Configuration ────────────────────────────────────────────────────
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token-here
PROJECT_KEY=SCRUM

# Zephyr Essential Cloud API v2.8
# Base URL (default is https://prod-api.zephyr4jiracloud.com/v2)
ZEPHYR_BASE_URL=https://prod-api.zephyr4jiracloud.com/v2
# API Token from: Jira → Apps → Zephyr Essentials → API Keys
ZEPHYR_ACCESS_KEY=your-zephyr-access-key-here

ISSUE_KEY=SCRUM-6
# Issue type used when auto-creating failure tickets (must exist in your project)
JIRA_BUG_ISSUETYPE=Bug
PORT=3000

# Jira Webhooks — Auto-trigger pipeline on story events
# Set a secret for HMAC-SHA256 signature validation (optional but recommended)
# WEBHOOK_SECRET=your-random-secret-here
# Comma-separated Jira statuses that trigger the pipeline
WEBHOOK_TRIGGER_STATUSES=In Progress,Selected for Development,To Do

# API Authentication — protects manual trigger and status endpoints
# Set a random secret; pass as: Authorization: Bearer <secret>
# API_SECRET=your-random-api-secret-here

# Applitools Eyes — Visual AI Testing
# Get your key: https://applitools.com → Account → My API Key
APPLITOOLS_API_KEY=LyR1001LO10710721093JYIC5MiCq0FCZuSho6I9a6kaUyHlU110
APPLITOOLS_APP_NAME=OrangeHRM
APPLITOOLS_BATCH_NAME=OrangeHRM QA Suite
# APPLITOOLS_SERVER_URL=https://eyesapi.applitools.com
# APPLITOOLS_MATCH_LEVEL=Strict
# Ultrafast Grid — cross-browser / responsive testing
# Set to "true" to render checkpoints on Chrome, Firefox, Safari, Edge, iPhone, Pixel
# USE_ULTRAFAST_GRID=true
# APPLITOOLS_CONCURRENCY=5

# CI/CD batch grouping — set this in your pipeline (e.g. GitHub run ID)
# APPLITOOLS_BATCH_ID=${{ github.run_id }}